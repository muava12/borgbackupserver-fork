#!/usr/bin/env bash
#
# BBS Migration Restore — imports config/agents/settings from a bbs-dump archive
# into a fresh BBS install. Does NOT touch repos, jobs, or archives.
#
# Prerequisites:
#   - Fresh BBS install completed (bin/bbs-install)
#   - Database has schema applied (installer does this automatically)
#
# Usage:
#   sudo bash /var/www/bbs/bin/bbs-migrate-restore /path/to/bbs-dump-YYYYMMDD-HHMMSS.tar.gz
#
# What this does:
#   1. Restores APP_KEY from the old server (required for SSH key decryption)
#   2. Imports config tables (agents, plugins, settings, users, etc.)
#   3. Re-provisions Unix users and SSH authorized_keys for all agents
#
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BOLD='\033[1m'; NC='\033[0m'
ok()   { echo -e "  ${GREEN}✔${NC} $*"; }
warn() { echo -e "  ${YELLOW}⚠${NC} $*"; }
die()  { echo -e "  ${RED}✘${NC} $*"; exit 1; }

BBS_DIR="/var/www/bbs"
ENV_FILE="$BBS_DIR/config/.env"
SSH_HELPER="$BBS_DIR/bin/bbs-ssh-helper"
ARCHIVE="${1:-}"

echo -e "${BOLD}BBS Migration Restore${NC}"
echo ""

# Preflight checks
[[ "$(id -u)" -eq 0 ]] || die "Must run as root (use sudo)"
[[ -n "$ARCHIVE" ]] || die "Usage: bbs-migrate-restore <bbs-dump-archive.tar.gz>"
[[ -f "$ARCHIVE" ]] || die "Archive not found: $ARCHIVE"
[[ -f "$SSH_HELPER" ]] || die "bbs-ssh-helper not found — run bbs-install first"

# Extract archive
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT
tar -xzf "$ARCHIVE" -C "$TMPDIR"
DUMP_DIR=$(find "$TMPDIR" -maxdepth 1 -type d -name 'bbs-dump-*' | head -1)
[[ -d "$DUMP_DIR" ]] || die "Invalid archive — no bbs-dump-* directory found"

echo -e "  Archive: $(basename "$ARCHIVE")"
echo ""

# ── Step 1: Restore .env ─────────────────────────────────────────
echo -e "${BOLD}[1/3] Restoring .env${NC}"

if [[ -f "$ENV_FILE" ]]; then
    # Existing .env — preserve DB credentials, merge APP_KEY from dump
    if [[ -f "$DUMP_DIR/dot-env" ]]; then
        OLD_APP_KEY=$(grep -oP '^APP_KEY=\K.*' "$DUMP_DIR/dot-env" || echo "")
        if [[ -n "$OLD_APP_KEY" ]]; then
            sed -i "s|^APP_KEY=.*|APP_KEY=$OLD_APP_KEY|" "$ENV_FILE"
            ok "Restored APP_KEY from dump (needed for SSH key decryption)"
        fi
    fi
    ok "Kept existing .env DB credentials"
elif [[ -f "$DUMP_DIR/dot-env" ]]; then
    # No .env yet — copy from dump, then fix DB_PASS to match this server
    mkdir -p "$(dirname "$ENV_FILE")"
    cp "$DUMP_DIR/dot-env" "$ENV_FILE"
    chmod 600 "$ENV_FILE"
    chown www-data:www-data "$ENV_FILE"
    ok "Restored .env from dump"

    # Reset the bbs DB user password to match what's in the dump
    DUMP_DB_USER=$(grep -oP '^DB_USER=\K.*' "$ENV_FILE" || echo "bbs")
    DUMP_DB_PASS=$(grep -oP '^DB_PASS=\K.*' "$ENV_FILE" || echo "")
    if [[ -n "$DUMP_DB_PASS" ]]; then
        mysql -e "ALTER USER '${DUMP_DB_USER}'@'localhost' IDENTIFIED BY '$DUMP_DB_PASS';" 2>/dev/null \
            && ok "Updated MySQL password for '$DUMP_DB_USER' to match dump" \
            || warn "Could not update MySQL password — you may need to update DB_PASS in .env"
    fi
else
    die "No .env in dump and no existing .env — cannot continue"
fi
echo ""

# ── Step 2: Import table data ─────────────────────────────────────
echo -e "${BOLD}[2/3] Importing tables${NC}"

# Read DB credentials
DB_HOST=$(grep -oP '^DB_HOST=\K.*' "$ENV_FILE" || echo "localhost")
DB_NAME=$(grep -oP '^DB_NAME=\K.*' "$ENV_FILE" || echo "bbs")
DB_USER=$(grep -oP '^DB_USER=\K.*' "$ENV_FILE" || die "DB_USER not in .env")
DB_PASS=$(grep -oP '^DB_PASS=\K.*' "$ENV_FILE" || die "DB_PASS not in .env")

MYSQL="mysql -h $DB_HOST -u $DB_USER -p$DB_PASS $DB_NAME"

# Disable FK checks during import
$MYSQL -e "SET FOREIGN_KEY_CHECKS=0;" 2>/dev/null

IMPORTED=0
FAILED=0
for sql_file in "$DUMP_DIR"/*.sql; do
    [[ -f "$sql_file" ]] || continue
    TABLE=$(basename "$sql_file" .sql)

    # Truncate existing data first (fresh install has empty tables)
    $MYSQL -e "TRUNCATE TABLE \`$TABLE\`" 2>/dev/null || true

    if $MYSQL < "$sql_file" 2>/dev/null; then
        COUNT=$($MYSQL -sN -e "SELECT COUNT(*) FROM \`$TABLE\`" 2>/dev/null || echo "?")
        ok "$TABLE ($COUNT rows)"
        ((IMPORTED++))
    else
        warn "$TABLE — import failed (table may not exist yet)"
        ((FAILED++))
    fi
done

$MYSQL -e "SET FOREIGN_KEY_CHECKS=1;" 2>/dev/null

echo ""
echo -e "  Imported: $IMPORTED, Failed: $FAILED"
echo ""

# ── Step 3: Re-provision Unix users ───────────────────────────────
echo -e "${BOLD}[3/3] Re-provisioning SSH users${NC}"

# Get storage_path from settings
STORAGE_PATH=$($MYSQL -sN \
    -e "SELECT \`value\` FROM settings WHERE \`key\` = 'storage_path'" 2>/dev/null || true)

if [[ -z "$STORAGE_PATH" ]]; then
    warn "No storage_path in settings — skipping SSH user provisioning"
    echo -e "  You'll need to create repos and re-provision SSH access manually."
else
    # Query agents with SSH keys
    AGENTS=$($MYSQL -sN \
        -e "SELECT id, name, ssh_unix_user, ssh_public_key
            FROM agents
            WHERE ssh_unix_user IS NOT NULL
              AND ssh_unix_user != ''
              AND ssh_public_key IS NOT NULL
              AND ssh_public_key != ''
            ORDER BY id" 2>/dev/null || true)

    if [[ -z "$AGENTS" ]]; then
        warn "No agents with SSH keys found"
    else
        PROVISIONED=0
        PROV_FAILED=0
        while IFS=$'\t' read -r AGENT_ID AGENT_NAME UNIX_USER PUBLIC_KEY; do
            [[ -z "$UNIX_USER" ]] && continue
            HOME_DIR="${STORAGE_PATH%/}/${AGENT_ID}"

            # Create home directory
            mkdir -p "$HOME_DIR" 2>/dev/null || true

            if sudo "$SSH_HELPER" create-user "$UNIX_USER" "$HOME_DIR" "$PUBLIC_KEY" 2>/dev/null; then
                ok "$AGENT_NAME → $UNIX_USER ($HOME_DIR)"
                ((PROVISIONED++))
            else
                # User might already exist from a previous attempt
                if id "$UNIX_USER" &>/dev/null; then
                    warn "$AGENT_NAME → $UNIX_USER already exists, updating authorized_keys"
                    SSH_DIR="$HOME_DIR/.ssh"
                    mkdir -p "$SSH_DIR"
                    RESTRICTION="command=\"borg serve --restrict-to-path $HOME_DIR --append-only\",restrict"
                    echo "$RESTRICTION $PUBLIC_KEY" > "$SSH_DIR/authorized_keys"
                    chown -R "$UNIX_USER:$UNIX_USER" "$SSH_DIR"
                    chmod 700 "$SSH_DIR"
                    chmod 600 "$SSH_DIR/authorized_keys"
                    ((PROVISIONED++))
                else
                    warn "$AGENT_NAME → $UNIX_USER — failed to provision"
                    ((PROV_FAILED++))
                fi
            fi
        done <<< "$AGENTS"

        echo ""
        echo -e "  Provisioned: $PROVISIONED, Failed: $PROV_FAILED"
    fi
fi

# Fix ownership
chown -R www-data:www-data "$BBS_DIR/config" 2>/dev/null || true

echo ""
echo -e "${GREEN}${BOLD}Migration restore complete!${NC}"
echo ""
echo -e "  ${BOLD}What was restored:${NC}"
echo -e "    • Users and login credentials"
echo -e "    • All agents (clients) and their SSH keys"
echo -e "    • Plugins and plugin configurations"
echo -e "    • Settings and notification services"
echo -e "    • Backup templates"
echo ""
echo -e "  ${BOLD}What you still need to do:${NC}"
echo -e "    1. Log in to the web UI and verify settings"
echo -e "    2. Create new repositories for each agent"
echo -e "    3. Create new backup plans (or recreate from templates)"
echo -e "    4. Agents will reconnect automatically — ${GREEN}no agent reinstall needed${NC}"
echo ""
echo -e "  ${YELLOW}Note:${NC} Borg repos must be re-initialized. Old backup history"
echo -e "  is not carried over — this is a fresh start with all config intact."
