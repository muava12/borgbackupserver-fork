#!/usr/bin/env bash
#
# BBS Self-Backup — comprehensive disaster recovery backup.
#
# Usage:
#   sudo /var/www/bbs/bin/bbs-backup [backup_dir]
#
# Creates a timestamped tar.gz containing:
#   - dump.sql          Full MySQL dump (excludes catalog tables)
#   - env               config/.env (APP_KEY, DB credentials, etc.)
#   - version           BBS version at time of backup
#   - ssh-host-keys/    SSH host keys (so agents don't get "host key changed" errors)
#   - cron              Scheduler cron job definition
#   - sudoers/          Sudoers files for www-data privileges
#
# Options:
#   --with-catalogs     Also export ClickHouse catalog data (can be large)
#   --keep N            Keep the N most recent backups (default: 7)
#
# Keeps the 7 most recent backups by default, deletes older ones.
#
set -euo pipefail

# Parse options
WITH_CATALOGS=0
KEEP=7
POSITIONAL=()
while [ $# -gt 0 ]; do
    case "$1" in
        --with-catalogs) WITH_CATALOGS=1; shift ;;
        --keep) KEEP="${2:-7}"; shift 2 ;;
        *) POSITIONAL+=("$1"); shift ;;
    esac
done

BBS_DIR="${BBS_DIR:-/var/www/bbs}"
BACKUP_DIR="${POSITIONAL[0]:-/var/bbs/backups}"

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (use sudo)"
    exit 1
fi

ENV_FILE="$BBS_DIR/config/.env"
if [ ! -f "$ENV_FILE" ]; then
    echo "Error: .env not found at $ENV_FILE"
    exit 1
fi

# Read DB credentials from .env
DB_HOST=$(grep '^DB_HOST=' "$ENV_FILE" | cut -d= -f2-)
DB_NAME=$(grep '^DB_NAME=' "$ENV_FILE" | cut -d= -f2-)
DB_USER=$(grep '^DB_USER=' "$ENV_FILE" | cut -d= -f2-)
DB_PASS=$(grep '^DB_PASS=' "$ENV_FILE" | cut -d= -f2-)

if [ -z "$DB_NAME" ] || [ -z "$DB_USER" ]; then
    echo "Error: could not read DB credentials from .env"
    exit 1
fi

# Create backup directory (owned by root, readable by www-data for S3 sync)
mkdir -p "$BACKUP_DIR"
chown root:www-data "$BACKUP_DIR"
chmod 750 "$BACKUP_DIR"

# Work in a temp directory
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# 1. MySQL dump (exclude MyISAM catalog tables to avoid lock contention)
echo "[1/5] Dumping MySQL database '$DB_NAME'..."
IGNORE_TABLES=()
for t in $(mysql -h "${DB_HOST:-localhost}" -u "$DB_USER" -p"$DB_PASS" -N -e \
    "SELECT TABLE_NAME FROM information_schema.TABLES
     WHERE TABLE_SCHEMA='$DB_NAME'
       AND (TABLE_NAME LIKE 'file\_catalog\_%' OR TABLE_NAME LIKE 'catalog\_dirs\_%')" 2>/dev/null); do
    IGNORE_TABLES+=(--ignore-table="$DB_NAME.$t")
done
mysqldump \
    -h "${DB_HOST:-localhost}" \
    -u "$DB_USER" \
    -p"$DB_PASS" \
    --single-transaction \
    --routines \
    --triggers \
    "${IGNORE_TABLES[@]}" \
    "$DB_NAME" > "$TMPDIR/dump.sql" 2>/dev/null
echo "  OK"

# 2. Copy .env and VERSION
echo "[2/5] Backing up config..."
cp "$ENV_FILE" "$TMPDIR/env"
if [ -f "$BBS_DIR/VERSION" ]; then
    cp "$BBS_DIR/VERSION" "$TMPDIR/version"
else
    echo "unknown" > "$TMPDIR/version"
fi
echo "  OK"

# 3. SSH host keys (critical — agents verify these on every connection)
echo "[3/5] Backing up SSH host keys..."
mkdir -p "$TMPDIR/ssh-host-keys"
cp /etc/ssh/ssh_host_*_key /etc/ssh/ssh_host_*_key.pub "$TMPDIR/ssh-host-keys/" 2>/dev/null || true
KEY_COUNT=$(ls "$TMPDIR/ssh-host-keys/" 2>/dev/null | wc -l)
if [ "$KEY_COUNT" -gt 0 ]; then
    echo "  OK ($KEY_COUNT files)"
else
    echo "  Warning: no SSH host keys found"
fi

# 4. ClickHouse catalog data (optional — can be large, rebuilds from repos)
if [ "$WITH_CATALOGS" -eq 1 ]; then
    echo "[4/5] Backing up ClickHouse catalogs..."
    if command -v clickhouse-client &>/dev/null && curl -sf http://localhost:8123/ping >/dev/null 2>&1; then
        clickhouse-client -d bbs --query \
            "SELECT * FROM file_catalog FORMAT CSVWithNames" \
            > "$TMPDIR/clickhouse-file-catalog.csv" 2>/dev/null || true
        if [ -s "$TMPDIR/clickhouse-file-catalog.csv" ]; then
            ROWS=$(wc -l < "$TMPDIR/clickhouse-file-catalog.csv")
            ROWS=$((ROWS - 1))  # subtract header
            echo "  OK ($ROWS rows exported)"
        else
            rm -f "$TMPDIR/clickhouse-file-catalog.csv"
            echo "  OK (catalog is empty)"
        fi
    else
        echo "  Skipped (ClickHouse not running)"
    fi
else
    echo "[4/5] Skipping ClickHouse catalogs (use --with-catalogs to include)"
fi

# 5. Sudoers and cron config
echo "[5/5] Backing up system config..."
mkdir -p "$TMPDIR/sudoers"
[ -f /etc/sudoers.d/bbs-ssh-helper ] && cp /etc/sudoers.d/bbs-ssh-helper "$TMPDIR/sudoers/" 2>/dev/null || true
[ -f /etc/sudoers.d/bbs-borg ] && cp /etc/sudoers.d/bbs-borg "$TMPDIR/sudoers/" 2>/dev/null || true
[ -f /etc/cron.d/bbs-scheduler ] && cp /etc/cron.d/bbs-scheduler "$TMPDIR/cron" 2>/dev/null || true
echo "  OK"

# Create tar.gz
echo "Creating backup archive..."
TIMESTAMP=$(date '+%Y-%m-%d_%H%M%S')
ARCHIVE="bbs-backup-${TIMESTAMP}.tar.gz"
tar -czf "$BACKUP_DIR/$ARCHIVE" -C "$TMPDIR" .
chown root:www-data "$BACKUP_DIR/$ARCHIVE"
chmod 640 "$BACKUP_DIR/$ARCHIVE"

SIZE=$(du -h "$BACKUP_DIR/$ARCHIVE" | cut -f1)
echo ""
echo "Backup created: $BACKUP_DIR/$ARCHIVE ($SIZE)"

# Retention — keep newest $KEEP, delete the rest
cd "$BACKUP_DIR"
# shellcheck disable=SC2012
ls -1t bbs-backup-*.tar.gz 2>/dev/null | tail -n +$((KEEP + 1)) | while read -r old; do
    rm -f "$old"
    echo "Removed old backup: $old"
done

echo "OK"
