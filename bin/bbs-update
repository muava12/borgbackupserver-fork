#!/usr/bin/env bash
#
# BBS Update — thin wrapper that pulls code, then hands off to bbs-update-run.
#
# This script is loaded into memory by bash before execution. After git pull,
# the on-disk copy may have changed, but bash keeps running the old version.
# By exec-ing bbs-update-run after the pull, we guarantee all post-pull steps
# always use the freshly-pulled code.
#
# Usage:
#   sudo /var/www/bbs/bin/bbs-update [bbs_dir] [git_tag|main]
#
set -euo pipefail

BBS_DIR="${1:-/var/www/bbs}"
GIT_TAG="${2:-}"

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: must run as root (use sudo)"
    exit 1
fi

if [ ! -d "$BBS_DIR" ]; then
    echo "Error: BBS directory not found at $BBS_DIR"
    exit 1
fi

echo "=== BBS Update ==="
echo ""

git config --global --add safe.directory "$BBS_DIR" 2>/dev/null || true

# Pull / checkout code
if [ -n "$GIT_TAG" ]; then
    echo "[1/9] Upgrading to $GIT_TAG..."
    git -C "$BBS_DIR" fetch --all --tags --force
    git -C "$BBS_DIR" checkout main 2>/dev/null || true
    if [ "$GIT_TAG" = "main" ]; then
        git -C "$BBS_DIR" reset --hard origin/main
    else
        git -C "$BBS_DIR" reset --hard "$GIT_TAG"
    fi
else
    echo "[1/9] Checking for latest release..."
    git -C "$BBS_DIR" fetch --all --tags --force
    LATEST_TAG=$(git -C "$BBS_DIR" tag --sort=-v:refname | grep -E '^v[0-9]' | head -1)
    if [ -n "$LATEST_TAG" ]; then
        echo "  Upgrading to $LATEST_TAG"
        git -C "$BBS_DIR" checkout main 2>/dev/null || true
        git -C "$BBS_DIR" reset --hard "$LATEST_TAG"
    else
        echo "  No release tags found, pulling main"
        git -C "$BBS_DIR" checkout main 2>/dev/null || true
        git -C "$BBS_DIR" pull
    fi
fi

# Hand off to the freshly-pulled run script
exec bash "$BBS_DIR/bin/bbs-update-run" "$BBS_DIR"
